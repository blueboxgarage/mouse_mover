{
  "manifest_version": 3,
  "name": "Mouse Mover",
  "version": "1.0.0",
  "description": "Animates a moving cursor inside the active tab.",
  "permissions": ["activeTab"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Mouse Mover",
    "default_popup": "popup.html"
  }
}
